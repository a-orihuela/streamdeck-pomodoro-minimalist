{
    "scripts": {
        "build": "rollup -c",
        "watch": "rollup -c -w --watch.onEnd=\"node scripts/restart.mjs\"",
        "lint": "eslint --max-warnings 0",
        "validate": "streamdeck validate *.sdPlugin",
        "pack": "streamdeck pack *.sdPlugin",
        "sync": "node scripts/sync-config.mjs"
    },
    "type": "module",
    "prettier": "@elgato/prettier-config",
    "devDependencies": {
        "@elgato/cli": "^1.7.4",
        "@elgato/eslint-config": "^0.3.2",
        "@elgato/prettier-config": "^0.3.3",
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-node-resolve": "^15.2.2",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.1.0",
        "@tsconfig/node20": "^20.1.2",
        "@types/node": "~24.1.0",
        "rollup": "^4.0.2",
        "tslib": "^2.6.2",
        "typescript": "^5.2.2"
    },
    "dependencies": {
        "@elgato/streamdeck": "^2.1.0"
    }
}
